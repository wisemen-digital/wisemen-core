{
  "name": "@wisemen/eslint-plugin-vue",
  "type": "module",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Eslint rules extended for Wisemen",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/wisemen-digital/wisemen-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/eslint-plugin"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typings": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "pub:release": "pnpm publish --access public",
    "cleanup": "rimraf dist/ node_modules/ .turbo/",
    "lint": "eslint .",
    "test": "vitest --run",
    "typecheck": "pnpm tsc"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "catalog:peer",
    "eslint": "catalog:peer",
    "typescript": "catalog:peer"
  },
  "dependencies": {
    "@typescript-eslint/scope-manager": "catalog:lint",
    "@typescript-eslint/type-utils": "catalog:lint",
    "@typescript-eslint/utils": "catalog:lint",
    "graphemer": "catalog:general",
    "ts-api-utils": "catalog:general"
  },
  "devDependencies": {
    "@wisemen/eslint-config-vue": "catalog:lint",
    "eslint": "catalog:lint",
    "rimraf": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build"
  }
}
