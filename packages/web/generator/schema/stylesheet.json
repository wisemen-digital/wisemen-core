{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "format": "uri",
      "type": "string"
    },
    "colors": {
      "additionalProperties": false,
      "patternProperties": {
        ".*": {
          "additionalProperties": false,
          "properties": {
            "dark": {
              "pattern": "^#(?:[0-9a-fA-F]{3}){1,2}$",
              "type": "string"
            },
            "light": {
              "pattern": "^#(?:[0-9a-fA-F]{3}){1,2}$",
              "type": "string"
            }
          },
          "required": ["light", "dark"],
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "required": ["colors"],
  "title": "Theme Color Schema",
  "type": "object"
}
