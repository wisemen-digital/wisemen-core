{
  "name": "@wisemen/vue-core-auth",
  "type": "module",
  "version": "3.1.3",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/web/auth"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typings": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "cleanup": "rimraf dist/ node_modules/ .turbo/",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp && npm publish",
    "test": "vitest --run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "pkce-challenge": "catalog:general"
  },
  "peerDependencies": {
    "vue": "catalog:peer",
    "vue-router": "catalog:peer"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@wisemen/eslint-config-vue": "workspace:*",
    "bumpp": "catalog:build",
    "eslint": "catalog:lint",
    "rimraf": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vue": "catalog:vue",
    "vue-router": "catalog:vue",
    "vitest": "catalog:test"
  }
}
