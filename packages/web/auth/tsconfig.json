{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "es2018"
  },
  "include": [
    "eslint.config.ts",
    "src/**/*.ts",
    "vitest.config.ts"
  ]
}
