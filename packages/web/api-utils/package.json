{
  "name": "@wisemen/vue-core-api-utils",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "version": "1.0.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/api-utils"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typings": "./dist/index.d.mts",
  "keywords": [
    "tanstack-intent",
    "vue-query",
    "result",
    "error-handling"
  ],
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pub:release": "pnpm publish --access public",
    "pub:beta": "pnpm publish --no-git-checks --access public --tag beta",
    "pub:next": "pnpm publish --no-git-checks --access public --tag next",
    "cleanup": "rimraf dist/ node_modules/ .turbo/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --run",
    "typecheck": "pnpm tsc"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "catalog:peer",
    "neverthrow": "catalog:peer",
    "vue": "catalog:peer"
  },
  "devDependencies": {
    "@tanstack/intent": "catalog:tooling",
    "@types/node": "catalog:types",
    "@wisemen/eslint-config-vue": "workspace:*",
    "eslint": "catalog:lint",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vue": "catalog:vue",
    "vitest": "catalog:test"
  }
}
