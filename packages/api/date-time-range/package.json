{
  "name": "@wisemen/date-time-range",
  "version": "1.0.22",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "imports": {
    "#src/*": "./dist/*"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "lint:oxlint": "oxlint --type-aware lib",
    "lint:eslint": "eslint lib",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "pnpm run build",
    "test": "node --env-file=.env.test --test ./dist/**/*.test.js",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "author": "Maarten Sijmkens",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/date-time-range"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer",
    "@nestjs/swagger": "catalog:backend-peer",
    "class-transformer": "catalog:backend-peer",
    "class-validator": "catalog:backend-peer",
    "dayjs": "catalog:backend-peer",
    "typeorm": "catalog:backend-peer"
  },
  "devDependencies": {
    "@types/node": "catalog:backend",
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint-api",
    "expect": "catalog:test",
    "typescript": "catalog:peer"
  },
  "dependencies": {
    "@wisemen/pagination": "workspace:*",
    "@wisemen/validators": "workspace:*"
  }
}
