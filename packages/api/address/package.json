{
  "name": "@wisemen/address",
  "version": "0.3.6",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "npm run clean && npm run build",
    "test": "node --env-file=.env.test --test ./**/*.test.js",
    "lint:oxlint": "oxlint --type-aware lib",
    "lint:eslint": "eslint --cache",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer",
    "@nestjs/swagger": "catalog:backend-peer",
    "class-transformer": "catalog:backend-peer",
    "class-validator": "catalog:backend-peer",
    "typeorm": "catalog:backend-peer"
  },
  "dependencies": {
    "@wisemen/coordinates": "workspace:*",
    "@wisemen/validators": "workspace:*"
  },
  "devDependencies": {
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint",
    "expect": "catalog:test",
    "typescript": "catalog:peer",
    "pg": "catalog:backend"
  },
  "author": "Kobe Kwanten",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/address"
  }
}
