{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "target": "esnext",
    "module": "NodeNext",
    "types": [
      "node"
    ],
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "include": [
    "./lib/**/*.ts"
  ],
  "exclude": []
}
