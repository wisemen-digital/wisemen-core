{
  "name": "@wisemen/nestjs-typeorm",
  "version": "0.2.1",
  "publishConfig": {
    "access": "public"
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "lint:oxlint": "oxlint --type-aware lib",
    "lint:eslint": "eslint lib",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "pnpm run build",
    "test": "node --env-file=.env --test ./**/*.test.js",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer",
    "@nestjs/config": "catalog:backend-peer",
    "@nestjs/typeorm": "catalog:backend-peer",
    "change-case": "catalog:backend-peer",
    "class-validator": "catalog:backend-peer",
    "pg": "catalog:backend-peer",
    "typeorm": "catalog:backend-peer"
  },
  "devDependencies": {
    "@types/node": "catalog:backend",
    "eslint": "catalog:lint",
    "expect": "catalog:test",
    "typescript": "catalog:peer",
    "@wisemen/eslint-config-nestjs": "workspace:*"
  },
  "author": "Joren Vandeweyer",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/nestjs-typeorm"
  }
}
