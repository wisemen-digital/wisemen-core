{
  "name": "@wisemen/monetary",
  "version": "0.4.2",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "npm run clean && npm run build",
    "test": "node --test ./dist/**/*.test.js",
    "lint:oxlint": "oxlint --type-aware",
    "lint:eslint": "eslint --cache",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer",
    "@nestjs/swagger": "catalog:backend-peer",
    "class-transformer": "catalog:backend-peer",
    "class-validator": "catalog:backend-peer",
    "typeorm": "catalog:backend-peer"
  },
  "devDependencies": {
    "@types/node": "catalog:backend",
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint-api",
    "expect": "catalog:test",
    "typescript": "catalog:peer"
  },
  "author": "Maarten Sijmkens",
  "contributors": [
    "Kobe Kwanten"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/monetary"
  },
  "dependencies": {
    "@wisemen/nestjs-typeorm": "workspace:*"
  }
}
