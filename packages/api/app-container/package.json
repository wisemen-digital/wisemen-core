{
  "name": "@wisemen/app-container",
  "version": "4.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A package for a nest app container in kubernetes",
  "directories": {
    "example": "examples"
  },
  "type": "module",
  "exports": {
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "import": "./dist/fastify/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "lint": "eslint lib",
    "prebuild": "rm -rf ./dist",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "npm run clean && npm run build",
    "test": "node --test",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "devDependencies": {
    "@nestjs/common": "catalog:backend",
    "@nestjs/core": "catalog:backend",
    "@nestjs/platform-fastify": "catalog:backend",
    "@types/express": "catalog:backend",
    "@types/node": "catalog:backend",
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint",
    "fastify": ">=5.8.4",
    "typescript": "catalog:peer"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer",
    "@nestjs/platform-express": "catalog:backend-peer",
    "@nestjs/platform-fastify": "catalog:backend-peer",
    "express": "catalog:backend-peer",
    "fastify": "catalog:backend-peer"
  },
  "peerDependenciesMeta": {
    "@nestjs/platform-express": {
      "optional": true
    },
    "@nestjs/platform-fastify": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "author": "Joren Vandeweyer",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/app-container"
  },
  "bugs": {
    "url": "https://github.com/wisemen-digital/node-core/issues"
  },
  "homepage": "https://github.com/wisemen-digital/node-core/packages/app-container"
}
