{
  "name": "@wisemen/opentelemetry",
  "version": "0.1.4",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/opentelemetry"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "npm run clean && npm run build",
    "test": "node --test",
    "lint:oxlint": "oxlint --type-aware ",
    "lint:eslint": "eslint --cache",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "dependencies": {
    "@opentelemetry/exporter-logs-otlp-http": "catalog:backend",
    "@opentelemetry/exporter-metrics-otlp-proto": "catalog:backend",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:backend",
    "@opentelemetry/instrumentation": "catalog:backend",
    "@opentelemetry/instrumentation-aws-sdk": "catalog:backend",
    "@opentelemetry/instrumentation-http": "catalog:backend",
    "@opentelemetry/instrumentation-express": "catalog:backend",
    "@opentelemetry/instrumentation-nestjs-core": "catalog:backend",
    "@opentelemetry/instrumentation-pg": "catalog:backend",
    "@opentelemetry/instrumentation-redis": "catalog:backend",
    "@opentelemetry/resources": "catalog:backend",
    "@opentelemetry/sdk-logs": "catalog:backend",
    "@opentelemetry/sdk-metrics": "catalog:backend",
    "@opentelemetry/sdk-node": "catalog:backend",
    "@opentelemetry/sdk-trace-base": "catalog:backend"
  },
  "peerDependencies": {
    "@opentelemetry/api": "catalog:backend-peer",
    "@opentelemetry/api-logs": "catalog:backend-peer",
    "reflect-metadata": "catalog:backend-peer"
  },
  "devDependencies": {
    "@types/node": "catalog:backend",
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint",
    "typescript": "catalog:peer"
  },
  "author": "Kobe Kwanten",
  "contributors": [],
  "license": "SEE LICENSE IN LICENSE.md"
}
