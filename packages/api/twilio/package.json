{
  "name": "@wisemen/twilio",
  "version": "0.0.3",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "imports": {
    "#*": "./lib/*"
  },
  "scripts": {
    "prebuild": "rm -rf ./dist",
    "clean": "rm -rf ./dist",
    "build": "tsc",
    "pretest": "npm run clean && npm run build",
    "test": "node --env-file=.env.test --test ./**/*.test.js",
    "lint:oxlint": "oxlint --type-aware",
    "lint:eslint": "eslint --cache",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "prerelease": "npm run build",
    "release": "pnpx release-it"
  },
  "dependencies": {
    "twilio": "catalog:backend",
    "@wisemen/api-error": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:backend-peer"
  },
  "devDependencies": {
    "@wisemen/eslint-config-nestjs": "workspace:*",
    "eslint": "catalog:lint",
    "expect": "catalog:test",
    "typescript": "catalog:peer"
  },
  "author": "Kobe Kwanten",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/wisemen-digital/wisemen-core",
    "directory": "packages/twilio"
  }
}
